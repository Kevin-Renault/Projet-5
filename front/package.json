    "@angular/compiler-cli": "^19.2.18",
    "@cypress/angular": "^4.1.0",
    "@cypress/code-coverage": "^3.14.6",
    "@cypress/schematic": "^4.1.3",
    "@cypress/webpack-dev-server": "^5.4.1",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@jsdevtools/coverage-istanbul-loader": "^3.0.5",
    "@types/cypress": "^0.1.6",
    "@types/jasmine": "~4.0.0",
    "@types/jest": "^30.0.0",
    "cypress": "^15.11.0",
    "jasmine-core": "~4.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "^14.5.2",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
